NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medipulse

# Keycloak — use existing gx1-auth instance, new medipulse realm
KC_URL=http://localhost:8080
KC_REALM=medipulse

# Backend confidential client (service account for KC Admin API calls)
KC_CLIENT_ID=medipulse-api
KC_CLIENT_SECRET=change-me

# Redis (BullMQ job queues — AI recommendations + Audit events)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# Dedicated audit database — completely separate from the main app DB.
# Can be a different PostgreSQL instance (recommended for prod) or just a separate DB on the same host.
AUDIT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medipulse_audit

# Bull Board queue monitoring UI — share only with ops/system-admin users
# Access: GET /admin/queues  Authorization: Bearer <this-key>
BULL_BOARD_API_KEY=change-me-generate-a-strong-random-key

# Worker process port (liveness/readiness probes only)
WORKER_PORT=3001

# Email (AWS SES SMTP — used in production for notifications)
# Leave blank in development: emails are logged to console only
EMAIL_FROM=noreply@medipulse.ai
SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# OpenAI
OPENAI_API_KEY=sk-...

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# OpenTelemetry — optional, leave blank to disable tracing
# Accepts any OTLP-compatible endpoint: Grafana Cloud, AWS X-Ray collector, Jaeger, etc.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=medipulse-api
