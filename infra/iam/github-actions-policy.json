{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECRAuth",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "ECRPush",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:PutImage",
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer"
      ],
      "Resource": [
        "arn:aws:ecr:AWS_REGION:ACCOUNT_ID:repository/medipulse-api",
        "arn:aws:ecr:AWS_REGION:ACCOUNT_ID:repository/medipulse-worker"
      ]
    },
    {
      "Sid": "ECSReadTaskDef",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeTaskDefinition",
        "ecs:DescribeServices"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECSDeployServices",
      "Effect": "Allow",
      "Action": [
        "ecs:RegisterTaskDefinition",
        "ecs:UpdateService"
      ],
      "Resource": [
        "arn:aws:ecs:AWS_REGION:ACCOUNT_ID:service/medipulse/medipulse-api",
        "arn:aws:ecs:AWS_REGION:ACCOUNT_ID:service/medipulse/medipulse-worker",
        "arn:aws:ecs:AWS_REGION:ACCOUNT_ID:task-definition/medipulse-api:*",
        "arn:aws:ecs:AWS_REGION:ACCOUNT_ID:task-definition/medipulse-worker:*"
      ]
    },
    {
      "Sid": "PassTaskRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::ACCOUNT_ID:role/MedipulseEcsExecutionRole",
        "arn:aws:iam::ACCOUNT_ID:role/MedipulseApiTaskRole",
        "arn:aws:iam::ACCOUNT_ID:role/MedipulseWorkerTaskRole"
      ]
    }
  ]
}
