{
  "name": "medipulse-backend",
  "version": "0.1.0",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "worker": "nest start --entryFile worker",
    "worker:dev": "nest start --watch --entryFile worker",
    "worker:prod": "node dist/worker",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "migration:show": "npx typeorm-ts-node-commonjs migration:show -d src/data-source.ts",
    "seed:products": "npx ts-node -r tsconfig-paths/register src/scripts/seed-products.ts",
    "migration:generate:audit": "npx typeorm-ts-node-commonjs migration:generate -d src/data-source-audit.ts",
    "migration:run:audit": "npx typeorm-ts-node-commonjs migration:run -d src/data-source-audit.ts",
    "migration:revert:audit": "npx typeorm-ts-node-commonjs migration:revert -d src/data-source-audit.ts",
    "setup:local": "npx ts-node src/setup-local-db.ts"
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-otlp-http": "^0.26.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.6.0",
    "bullmq": "^5.77.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "csv-parse": "^6.2.1",
    "eventemitter2": "^6.4.9",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.1",
    "jwks-rsa": "^3.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "openai": "^4.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "dotenv": "^16.4.5",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  }
}
